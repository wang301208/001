# 助手 Podman environment
# Copy to zhushou.podman.env.local and set ZHUSHOU_GATEWAY_TOKEN (or use -e when running).
# This file can be used with:
#   zhushou_PODMAN_ENV=/path/to/zhushou.podman.env ./scripts/run-zhushou-podman.sh launch

# Required: gateway auth token. Generate with: openssl rand -hex 32
# Set this before running the container (or use run-zhushou-podman.sh which can generate it).
ZHUSHOU_GATEWAY_TOKEN=

# Optional: web provider (leave empty to skip)
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=

# Host port mapping (defaults; override if needed)
zhushou_PODMAN_GATEWAY_HOST_PORT=18789
zhushou_PODMAN_BRIDGE_HOST_PORT=18790

# Gateway bind (used by the launch script)
ZHUSHOU_GATEWAY_BIND=lan

# Optional: LLM provider API keys (for zero cost use Ollama locally or Groq free tier)
# OLLAMA_API_KEY=ollama-local
# GROQ_API_KEY=
