{
  "name": "@assistant/qa-lab",
  "version": "2026.4.16",
  "private": true,
  "description": "助手 QA lab plugin with private debugger UI and scenario runner",
  "type": "module",
  "dependencies": {
    "@copilotkit/aimock": "1.13.0",
    "playwright-core": "1.59.1"
  },
  "devDependencies": {
    "@assistant/plugin-sdk": "workspace:*",
    "assistant": "workspace:*"
  },
  "peerDependencies": {
    "assistant": ">=2026.4.16"
  },
  "peerDependenciesMeta": {
    "assistant": {
      "optional": true
    }
  },
  "assistant": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@assistant/qa-lab",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.16"
    }
  }
}
