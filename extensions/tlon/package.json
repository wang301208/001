{
  "name": "@assistant/tlon",
  "version": "2026.4.16",
  "description": "助手 Tlon/Urbit channel plugin",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "3.1028.0",
    "@aws-sdk/s3-request-presigner": "3.1028.0",
    "@tloncorp/tlon-skill": "0.3.5",
    "@urbit/aura": "^3.0.0"
  },
  "devDependencies": {
    "@assistant/plugin-sdk": "workspace:*",
    "assistant": "workspace:*"
  },
  "peerDependencies": {
    "assistant": ">=2026.4.16"
  },
  "peerDependenciesMeta": {
    "assistant": {
      "optional": true
    }
  },
  "assistant": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "tlon",
      "label": "Tlon",
      "selectionLabel": "Tlon (Urbit)",
      "docsPath": "/channels/tlon",
      "docsLabel": "tlon",
      "blurb": "decentralized messaging on Urbit; install the plugin to enable.",
      "order": 90,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@assistant/tlon",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    }
  }
}
