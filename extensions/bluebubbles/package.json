{
  "name": "@zhushou/bluebubbles",
  "version": "2026.4.16",
  "description": "助手 BlueBubbles channel plugin",
  "type": "module",
  "devDependencies": {
    "@zhushou/plugin-sdk": "workspace:*",
    "zhushou": "workspace:*"
  },
  "peerDependencies": {
    "zhushou": ">=2026.4.16"
  },
  "peerDependenciesMeta": {
    "zhushou": {
      "optional": true
    }
  },
  "zhushou": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "bluebubbles",
      "label": "BlueBubbles",
      "selectionLabel": "BlueBubbles (macOS app)",
      "detailLabel": "BlueBubbles",
      "docsPath": "/channels/bluebubbles",
      "docsLabel": "bluebubbles",
      "blurb": "iMessage via the BlueBubbles mac app + REST API.",
      "aliases": [
        "bb"
      ],
      "preferOver": [
        "imessage"
      ],
      "systemImage": "bubble.left.and.text.bubble.right",
      "order": 75
    },
    "install": {
      "npmSpec": "@zhushou/bluebubbles",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.16"
    },
    "build": {
      "zhushouVersion": "2026.4.16"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
