{
  "name": "@zhushou/zalo",
  "version": "2026.4.16",
  "description": "助手 Zalo channel plugin",
  "type": "module",
  "dependencies": {
    "undici": "8.0.2"
  },
  "devDependencies": {
    "@zhushou/plugin-sdk": "workspace:*",
    "zhushou": "workspace:*"
  },
  "peerDependencies": {
    "zhushou": ">=2026.4.16"
  },
  "peerDependenciesMeta": {
    "zhushou": {
      "optional": true
    }
  },
  "zhushou": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "zalo",
      "label": "Zalo",
      "selectionLabel": "Zalo (Bot API)",
      "docsPath": "/channels/zalo",
      "docsLabel": "zalo",
      "blurb": "Vietnam-focused messaging platform with Bot API.",
      "aliases": [
        "zl"
      ],
      "order": 80,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@zhushou/zalo",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.16"
    },
    "build": {
      "zhushouVersion": "2026.4.16"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
