{
  "name": "@assistant/nextcloud-talk",
  "version": "2026.4.16",
  "description": "助手 Nextcloud Talk channel plugin",
  "type": "module",
  "devDependencies": {
    "@assistant/plugin-sdk": "workspace:*",
    "assistant": "workspace:*"
  },
  "peerDependencies": {
    "assistant": ">=2026.4.16"
  },
  "peerDependenciesMeta": {
    "assistant": {
      "optional": true
    }
  },
  "assistant": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "nextcloud-talk",
      "label": "Nextcloud Talk",
      "selectionLabel": "Nextcloud Talk (self-hosted)",
      "docsPath": "/channels/nextcloud-talk",
      "docsLabel": "nextcloud-talk",
      "blurb": "Self-hosted chat via Nextcloud Talk webhook bots.",
      "aliases": [
        "nc-talk",
        "nc"
      ],
      "order": 65,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@assistant/nextcloud-talk",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.16"
    },
    "build": {
      "assistantVersion": "2026.4.16"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
